  <CalculatedFields>
    <Field Name="見出し_Cal" Formula="= System.String.IsNullOrEmpty(体系区分) ? &quot;&quot; : (体系区分.Substring(0, 1) == &quot;4&quot; ? &quot;（ 収益的収入 ）&quot; : (体系区分.Substring(0, 1) == &quot;5&quot; ? &quot;（ 収益的支出 ）&quot; : (体系区分.Substring(0, 1) == &quot;6&quot; ? &quot;（ 資本的収入 ）&quot; : (体系区分.Substring(0, 1) == &quot;7&quot; ? &quot;（ 資本的支出 ）&quot; : &quot;&quot;))))" FieldType="None" />
    <Field Name="タイトル_Cal" Formula="=帳票名" FieldType="None" />
    <Field Name="科目名称_Cal" Formula="= System.String.IsNullOrEmpty(予算名称) ? &quot;&quot; : (予算名称.Length &gt;= 24 ? 予算名称.Substring(0, 24) : 予算名称)" FieldType="None" />
    <Field Name="特定収入貯蔵品_Cal" Formula="= System.String.IsNullOrEmpty(体系区分) ? &quot;&quot; : ((体系区分.Substring(0, 1) == &quot;4&quot; || 体系区分.Substring(0, 1) == &quot;6&quot;) ? &quot;特定収入&quot; : ((体系区分.Substring(0, 1) == &quot;5&quot; || 体系区分.Substring(0, 1) == &quot;7&quot;) ? &quot; 貯蔵品&quot; : &quot;&quot;))" FieldType="None" />
    <Field Name="タイムスタンプ" FieldType="None" />
  </CalculatedFields>
  <Script><![CDATA[/// <summary>
/// レポート開始時（ReportStart）に初期処理を実行する。
/// - 全セクションの背景色を透明化（重ね表示・罫線の見え方対策）
/// - データソース確認後、出力順を揃えるためソートを適用
/// </summary>
public void ActiveReport_ReportStart()
{
	SetBgColorTransparentAllSections();
	
	if(!CheckDataSource()) return;
	ApplySort();
	
}

/// <summary>
/// データソースを「伝票日付→伝票区分→伝票番号→内訳予算細コード」の順で並べ替える。
/// 必要な列が揃っている場合のみ、DataView の Sort を使って出力順を統一する。
/// </summary>
private void ApplySort()
{
	System.Data.DataTable dt = rpt.DataSource as System.Data.DataTable;
	if (!dt.Columns.Contains("体系区分"))
	{
		Section3.Visible = false;
		Section8.Visible = false;
		return;
	}
	dt.Columns.Add("区分_col", typeof(string));
	for (int i = 0; i < dt.Rows.Count; i++)
	{
		string 体系区分_temp = Convert.ToString(dt.Rows[i]["体系区分"]);
		dt.Rows[i]["区分_col"] = GetCrystalSubstring(体系区分_temp, 1, 2);
	}
	
	// DataViewオブジェクトを作成し、並べ替え条件を設定
	System.Data.DataView dv = dt.DefaultView;
	dv.Sort = ("区分_col, SEQ");

	// 並べ替え後のDataViewをレポートに設定
	rpt.DataSource = dv.ToTable();
	rpt.DataMember = null;
}

public void Section5_Format()
{	
	if(!CheckDataSource()) return;
	
	#region 非表示
	this.Field6.Visible = rpt.Fields["見出区分"].Value.ToString().Contains("TIMESTAMPON");
	#endregion
	
	#region Formula [@タイムスタンプ]
	// カルチャの「言語-国/地域」を「日本語-日本」に設定します。
	System.Globalization.CultureInfo ci = new System.Globalization.CultureInfo("ja-JP");
	// 和暦を表すクラスです。
	System.Globalization.JapaneseCalendar jp = new System.Globalization.JapaneseCalendar();
	
	// 現在のカルチャで使用する暦を、和暦に設定します。
	ci.DateTimeFormat.Calendar = jp;
	// 「書式」「カルチャの書式情報」を使用し、文字列に変換します。
	this.Field6.Text = DateTime.Now.ToString("gg yy年MM月dd日 HH:mm:ss", ci);
	#endregion
}


/// <summary>
/// rpt.DataSource が存在し、System.Data.DataTable として有効か確認
/// </summary>
private bool CheckDataSource()
{
	// ブロック確認: DataSource が割り当てられているか（null でないか）を確認
	if (rpt.DataSource == null)
	{
		return false;
	}

	// ブロック確認: DataSource を DataTable にキャストし、キャストの成功を確認
	System.Data.DataTable dt = rpt.DataSource as System.Data.DataTable;
	if (dt == null)
	{
		return false;
	}

	return true;
}

// rpt 内のすべてのセクションに対してテキスト系コントロールの背景色を透過に設定する
private void SetBgColorTransparentAllSections()
{
	// 全セクションを順に処理
	foreach (GrapeCity.ActiveReports.SectionReportModel.Section sec in rpt.Sections)
	{
		// セクション内のコントロールを順に処理
		foreach (GrapeCity.ActiveReports.SectionReportModel.ARControl ctrl in sec.Controls)
		{
			// TextBox の場合は背景を透過にする
			if (ctrl is TextBox)
			{
				TextBox tbx = (TextBox) ctrl;
				tbx.BackColor = System.Drawing.Color.Transparent;
			}

			// Label の場合は背景を透過にする
			if (ctrl is Label)
			{
				GrapeCity.ActiveReports.SectionReportModel.Label lbl = (Label) ctrl;
				lbl.BackColor = System.Drawing.Color.Transparent;
			}
		}
	}
}

/// <summary>
/// 入力文字列からstart〜endまで（終端含む）の部分文字列を返す。CrystalReportのメソッドと同様（1-based）
/// </summary>
/// <param name="input">ソース文字列。</param>
/// <param name="start">開始インデックス（1-based）。</param>
/// <param name="end">終了インデックス（1-based、終端含む）。</param>
/// <returns>該当する部分文字列。入力無効かstartが範囲外なら空文字を返す。</returns>
private string GetCrystalSubstring(string input, int start, int end)
{
	// 0ベースに変換する
	start--;
	end--;
	// 入力チェック: inputがnull/empty、またはstartが文字列長を超える場合は空文字を返す
	if (string.IsNullOrEmpty(input) || start >= input.Length)
	{
		return "";
	}

	// 計算ブロック: 取得する長さを決定する。取得長を残り文字数を超えないようにクランプする。
	int length = Math.Min(end - start + 1, input.Length - start);
    
	// 結果取得ブロック: 計算済みの長さで start から substring を返す
	return input.Substring(start, length);
}
]]></Script>
