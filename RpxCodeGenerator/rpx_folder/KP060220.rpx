	決裁欄6.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 5);
	
	//	if {ヘッダデータ.決裁名称2} = "" then 1
	//	else 0
	if (rpt.Fields["決裁欄枠パターン"].Value.ToString() == ""){
		決裁名称2.ForeColor = Color.Transparent;
	}
	else{
		決裁名称2.ForeColor = Color.Black;
	}
}
