  <Script><![CDATA[public void Section1_Format()
{
	#region set BackColor transparent
	
	SetBgColerTransparent(Section1);
	SetBgColerTransparent(Section2);
	SetBgColerTransparent(Section3);
	SetBgColerTransparent(Section4);
	SetBgColerTransparent(Section5);
	SetBgColerTransparent(GroupFooterSection1);
	SetBgColerTransparent(GroupFooterSection2);
	SetBgColerTransparent(GroupHeaderSection1);
	SetBgColerTransparent(GroupHeaderSection2);

	#endregion
}

private void SetBgColerTransparent(GrapeCity.ActiveReports.SectionReportModel.Section sec)
{
	foreach (GrapeCity.ActiveReports.SectionReportModel.ARControl ctrl in sec.Controls)
	{
		if (ctrl is TextBox)
		{
			TextBox tbx = (TextBox) ctrl;
			tbx.BackColor = System.Drawing.Color.Transparent; 
		}
		if (ctrl is Label )
		{
			GrapeCity.ActiveReports.SectionReportModel.Label lbl = (Label) ctrl;
			lbl.BackColor = System.Drawing.Color.Transparent;
		}
	}
}


public void GroupFooterSection1_Format()
{
	#region 非表示
	this.Field9.Visible = rpt.Fields["見出区分"].Value.ToString().Contains("TIMESTAMPON");
	#endregion
	
	#region Formula [@タイムスタンプ]
	// カルチャの「言語-国/地域」を「日本語-日本」に設定します。
	System.Globalization.CultureInfo ci = new System.Globalization.CultureInfo("ja-JP");
	// 和暦を表すクラスです。
	System.Globalization.JapaneseCalendar jp = new System.Globalization.JapaneseCalendar();
	
	// 現在のカルチャで使用する暦を、和暦に設定します。
	ci.DateTimeFormat.Calendar = jp;
	// 「書式」「カルチャの書式情報」を使用し、文字列に変換します。
	this.Field9.Text = DateTime.Now.ToString("gg yy年MM月dd日 HH:mm:ss", ci);
	
	#endregion

}


public void Section3_Format()
{
	#region SET Alignment
	
	this.前残金額1.Alignment = TextAlignment.Right;
	this.借方金額1.Alignment = TextAlignment.Right;
	this.貸方金額1.Alignment = TextAlignment.Right;
	this.残高金額1.Alignment = TextAlignment.Right;
	this.SEQ1.Alignment = TextAlignment.Right;
	
	#endregion		
	
	this.前残金額1.Visible = (Convert.ToDecimal(rpt.Fields["前残金額"].Value) != 0);
	this.借方金額1.Visible = (Convert.ToDecimal(rpt.Fields["借方金額"].Value) != 0);
	this.貸方金額1.Visible = (Convert.ToDecimal(rpt.Fields["貸方金額"].Value) != 0);
	this.残高金額1.Visible = (Convert.ToDecimal(rpt.Fields["残高金額"].Value) != 0);
}


public void Section5_Format()
{
	#region SET Alignment
	
	this.Field9.Alignment = TextAlignment.Center;
	
	#endregion
}

public void ActiveReport_ReportStart()
{
	ApplySort();
}

private void ApplySort()
{
	if (rpt.DataSource == null) return;

	System.Data.DataTable dt = rpt.DataSource as System.Data.DataTable;
	if (dt == null || !dt.Columns.Contains("集計日付") || !dt.Columns.Contains("ページ") || !dt.Columns.Contains("SEQ")) 
	{
		return;
	}
	
	System.Data.DataView dv2 = new System.Data.DataView(dt);
	dv2.Sort = "集計日付, ページ, SEQ";


	rpt.DataSource = dv2;
	rpt.DataMember = null;
}

]]></Script>
