  <CalculatedFields>
    <Field Name="借方予算款コード" Formula="=(借方予算コード == &quot;&quot;) ? &quot;&quot; : 借方予算コード.Substring(0 ,2);" FieldType="None" />
    <Field Name="借方予算項コード" Formula="=(借方予算コード == &quot;&quot;) ? &quot;&quot; : 借方予算コード.Substring(2 ,2)" FieldType="None" />
    <Field Name="借方予算目コード" Formula="=(借方予算コード == &quot;&quot;) ? &quot;&quot; : 借方予算コード.Substring(4 ,2)" FieldType="None" />
    <Field Name="借方予算節コード" Formula="=(借方予算コード == &quot;&quot;) ? &quot;&quot; : 借方予算コード.Substring(6 ,2)" FieldType="None" />
    <Field Name="借方予算細コード" Formula="=(借方予算コード == &quot;&quot;) ? &quot;&quot; : 借方予算コード.Substring(8 ,2)" FieldType="None" />
    <Field Name="借方予算残額" Formula="=(借方予算コード == &quot;&quot;) ? &quot;&quot; : ((借方予算現額Cal.ToString() == &quot;&quot;) ? 0 : Convert.ToDecimal(借方予算現額Cal)) - ((借方予算執行額.ToString() == &quot;&quot;) ? 0 : Convert.ToDecimal(借方予算執行額))).ToString(&quot;F0&quot;);" FieldType="None" />
    <Field Name="借方税区分名称Cal" Formula="=(借方税区分 == &quot;1&quot; || 借方税区分 == &quot;2&quot;) ? &quot;課税&quot; : 借方税区分名称" FieldType="None" />
    <Field Name="借方款コード" Formula="=(借方科目コード == &quot;&quot;) ? &quot;&quot; : 借方科目コード.Substring(0 ,2)" FieldType="None" />
    <Field Name="借方項コード" Formula="=(借方科目コード == &quot;&quot;) ? &quot;&quot; : 借方科目コード.Substring(2 ,2)" FieldType="None" />
    <Field Name="借方目コード" Formula="=(借方科目コード == &quot;&quot;) ? &quot;&quot; : 借方科目コード.Substring(4 ,2)" FieldType="None" />
    <Field Name="借方節コード" Formula="=(借方科目コード == &quot;&quot;) ? &quot;&quot; : 借方科目コード.Substring(6, 2)" FieldType="None" />
    <Field Name="貸方款コード" Formula="=(貸方科目コード == &quot;&quot;) ? &quot;&quot; : 貸方科目コード.Substring(0, 2)" FieldType="None" />
    <Field Name="貸方項コード" Formula="=(貸方科目コード == &quot;&quot;) ? &quot;&quot; : 貸方科目コード.Substring(2, 2)" FieldType="None" />
    <Field Name="貸方目コード" Formula="=(貸方科目コード == &quot;&quot;) ? &quot;&quot; : 貸方科目コード.Substring(4, 2)" FieldType="None" />
    <Field Name="貸方節コード" Formula="=(貸方科目コード == &quot;&quot;) ? &quot;&quot; : 貸方科目コード.Substring(6, 2)" FieldType="None" />
    <Field Name="貸方予算款コード" Formula="=(貸方予算コード == &quot;&quot;) ? &quot;&quot; : 貸方予算コード.Substring(0, 2)" FieldType="None" />
    <Field Name="貸方予算項コード" Formula="=(貸方予算コード == &quot;&quot;) ? &quot;&quot; : 貸方予算コード.Substring(2, 2)" FieldType="None" />
    <Field Name="貸方予算目コード" Formula="=(貸方予算コード == &quot;&quot;) ? &quot;&quot; : 貸方予算コード.Substring(4, 2)" FieldType="None" />
    <Field Name="貸方予算節コード" Formula="=(貸方予算コード == &quot;&quot;) ? &quot;&quot; : 貸方予算コード.Substring(6, 2)" FieldType="None" />
    <Field Name="貸方予算細コード" Formula="=(貸方予算コード == &quot;&quot;) ? &quot;&quot; : 貸方予算コード.Substring(8, 2)" FieldType="None" />
    <Field Name="貸方予算残額" Formula="=(貸方予算コード == &quot;&quot; ) ? &quot;&quot;  :  ((long)貸方予算現額Cal - (long)貸方予算執行額Cal).ToString(&quot;F0&quot;);" FieldType="None" />
    <Field Name="貸方税区分名称Cal" Formula="=(貸方税区分 == &quot;1&quot; || 貸方税区分 == &quot;2&quot;) ? &quot;課税&quot; : 貸方税区分名称" FieldType="None" />
    <Field Name="借方予算現額Cal" Formula="=(借方予算コード == &quot;&quot; ) ? &quot;&quot;  :  (借方予算現額).ToString(&quot;F0&quot;);" FieldType="None" />
    <Field Name="貸方予算現額Cal" Formula="=(貸方予算コード == &quot;&quot; ) ? &quot;&quot;  :  (貸方予算現額).ToString(&quot;F0&quot;);" FieldType="None" />
    <Field Name="借方予算執行額" Formula="=(借方予算コード == &quot;&quot; ) ? &quot;&quot;  :  (借方執行額).ToString(&quot;F0&quot;);" FieldType="None" />
    <Field Name="貸方予算執行額" Formula="=(貸方予算コード == &quot;&quot; ) ? &quot;&quot;  :  (貸方執行額).ToString(&quot;F0&quot;);" FieldType="None" />
