// セクション内のテキストボックスの背景色を透明に設定する
private void SetBgColerTransparent(GrapeCity.ActiveReports.SectionReportModel.Section sec)
{
	foreach (GrapeCity.ActiveReports.SectionReportModel.ARControl ctrl in sec.Controls)
	{
		if (ctrl is TextBox)
		{
			TextBox tbx = (TextBox) ctrl;
			tbx.BackColor = System.Drawing.Color.Transparent; 
		}
		if (ctrl is Label )
		{
			GrapeCity.ActiveReports.SectionReportModel.Label lbl = (Label) ctrl;
			lbl.BackColor = System.Drawing.Color.Transparent;
		}
	}
}
public void Section3_BeforePrint()
{
		/*
	"if {伝票データ.借方予算コード} = '' 
	then ''
	else ToText(ToNumber({@借方予算現額}) - ToNumber({@借方予算執行額}),0)
	"*/
	long 借方予算現額Cal = rpt.CalculatedFields["借方予算現額Cal"].Value.ToString() == "" ? 0 : Convert.ToInt64(rpt.CalculatedFields["借方予算現額Cal"].Value.ToString());
	long 借方予算執行額 = rpt.CalculatedFields["借方予算執行額"].Value == "" ? 0 : Convert.ToInt64(rpt.CalculatedFields["借方予算執行額"].Value.ToString());
	long 借方予算残額 = 借方予算現額Cal - 借方予算執行額;
	Field16.Value = 借方予算残額;
	if(借方予算残額 == 0){Field16.Text = "";};
	
	long 貸方予算現額Cal = rpt.CalculatedFields["貸方予算現額Cal"].Value.ToString() == "" ? 0 : Convert.ToInt64(rpt.CalculatedFields["貸方予算現額Cal"].Value.ToString());
	long 貸方予算執行額 = rpt.CalculatedFields["貸方予算執行額"].Value == "" ? 0 : Convert.ToInt64(rpt.CalculatedFields["貸方予算執行額"].Value.ToString());
	long 貸方予算残額 = 貸方予算現額Cal - 貸方予算執行額;
	Field50.Value = 貸方予算残額;
	if(貸方予算残額 == 0){Field50.Text = "";};
	
}


