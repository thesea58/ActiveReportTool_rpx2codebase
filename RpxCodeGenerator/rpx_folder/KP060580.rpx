  <CalculatedFields>
    <Field Name="見出し" Formula="= System.String.IsNullOrEmpty(体系区分) ? &quot;&quot; : ((体系区分.Length &gt;= 1) ? ((体系区分.Substring(0, 1) == &quot;4&quot;) ? &quot;（ 収益的収入 ）&quot; : ((体系区分.Substring(0, 1) == &quot;5&quot;) ? &quot;（ 収益的支出 ）&quot; : ((体系区分.Substring(0, 1) == &quot;6&quot;) ? &quot;（ 資本的収入 ）&quot; : ((体系区分.Substring(0, 1) = &quot;7&quot;) ? &quot;（ 資本的支出 ）&quot; : &quot;&quot;)))) : &quot;&quot;)" FieldType="None" />
    <Field Name="タイトル" Formula="=帳票名" FieldType="None" />
    <Field Name="科目名称" Formula="=System.String.IsNullOrEmpty(予算名称) ? &quot;&quot; : ((予算名称.Length &gt; 24) ? 予算名称.Substring(0, 24) : 予算名称)" FieldType="None" />
    <Field Name="区分" FieldType="None" />
    <Field Name="特定収入貯蔵品" Formula="=System.String.IsNullOrEmpty(体系区分) ? &quot;&quot; : ((体系区分.Length &lt; 1) ? &quot;&quot; :((体系区分.Substring(0, 1) == &quot;4&quot;  || 体系区分.Substring(0, 1) == &quot;6&quot;) ? &quot;特定収入&quot; : ((体系区分.Substring(0, 1) == &quot;5&quot;  || 体系区分.Substring(0, 1) == &quot;7&quot;) ? &quot; 貯蔵品&quot; : &quot;&quot;)))" FieldType="None" />
    <Field Name="所属表示" Formula="=備考1" FieldType="None" />
    <Field Name="タイムスタンプ" FieldType="None" />
  </CalculatedFields>
  <Script><![CDATA[/// <summary>
/// レポート開始時（ReportStart）に一度だけ実行される初期化処理です。
/// - 全セクションの TextBox/Label の背景色を透過に統一
/// - DataSource（DataTable）の存在・必要列（体系区分）のチェック
/// - ソート用の補助列「区分_col」を作成し、体系区分の先頭1文字を設定
/// - 「区分_col」→「SEQ」の順で並び替えし、並び替え後の DataTable を DataSource に再設定
/// - データが無い／想定外の場合は HideSection() で表示を抑止
/// </summary>
public void ActiveReport_ReportStart()
{
	// rpt 内のすべてのセクションに対してテキスト系コントロールの背景色を透過に設定する
	SetBgColorTransparentAllSections();
	
	if (rpt.DataSource == null)
	{
		HideSection();
		return;
	}
	
	System.Data.DataTable dt = rpt.DataSource as System.Data.DataTable;
	if (dt == null || !dt.Columns.Contains("体系区分"))
	{
		HideSection();
		return;
	}
	
	// 列が存在しない場合は作成します。
	if (!dt.Columns.Contains("区分_col"))
	{
		dt.Columns.Add("区分_col", typeof(string));
	}
	
	for (int i = 0; i < dt.Rows.Count; i++)
	{
		dt.Rows[i]["区分_col"] = String.IsNullOrEmpty(Convert.ToString(dt.Rows[i]["体系区分"])) ? "" : dt.Rows[i]["体系区分"].ToString().Substring(0, 1);
	}
	
	// DataViewオブジェクトを作成し、並べ替え条件を設定
	System.Data.DataView dv = dt.DefaultView;
	dv.Sort = string.Join(",", new string[] { "区分_col", "SEQ" });

	// 並べ替え後のDataViewをレポートに設定
	rpt.DataSource = dv.ToTable();
	rpt.DataMember = null;
}

/// <summary>
/// Section5 の Format イベント。
/// - 見出区分の値により、タイムスタンプ表示（Field6）の表示/非表示を切り替える
/// - 表示する場合は、現在日時を「和暦 + 年月日 時分秒」形式で出力し、CalculatedField と Field6 に設定する
/// </summary>
public void Section5_Format()
{	
	#region 非表示
	this.Field6.Visible = SafeFieldStr("見出区分").Contains("TIMESTAMPON");
	#endregion
	
	#region Formula [@タイムスタンプ]
	// カルチャの「言語-国/地域」を「日本語-日本」に設定します。
	System.Globalization.CultureInfo ci = new System.Globalization.CultureInfo("ja-JP");
	// 和暦を表すクラスです。
	System.Globalization.JapaneseCalendar jp = new System.Globalization.JapaneseCalendar();
	
	// 現在のカルチャで使用する暦を、和暦に設定します。
	ci.DateTimeFormat.Calendar = jp;
	// 「書式」「カルチャの書式情報」を使用し、文字列に変換します。
	rpt.CalculatedFields["タイムスタンプ"].Value = DateTime.Now.ToString("gg yy年MM月dd日 HH:mm:ss", ci);
	this.Field6.Text = DateTime.Now.ToString("gg yy年MM月dd日 HH:mm:ss", ci);
	#endregion
}
/// <summary>
/// TextBox に DataField（空でない）が設定されている場合、レポート (rpt) の各セクション内の TextBox を非表示にします。
/// </summary>
private void HideSection()
{
	// レポートの各セクションをループ処理する
	foreach (GrapeCity.ActiveReports.SectionReportModel.Section sec in rpt.Sections)
	{
		// 現在のセクション内の各コントロールをループ処理する
		foreach (GrapeCity.ActiveReports.SectionReportModel.ARControl ctrl in sec.Controls)
		{
			// コントロールが TextBox の場合に処理を行う
			if (ctrl is TextBox) // 条件: コントロールの型を判定
			{
				TextBox tbx = (TextBox) ctrl;
				
				// TextBox に DataField（null または空でない）がある場合は非表示にする
				if (!String.IsNullOrEmpty(tbx.DataField))
				{
					tbx.Visible = false;
				}
			}
		}
	}
}
// rpt 内のすべてのセクションに対してテキスト系コントロールの背景色を透過に設定する
private void SetBgColorTransparentAllSections()
{
	// 全セクションを順に処理
	foreach (GrapeCity.ActiveReports.SectionReportModel.Section sec in rpt.Sections)
	{
		// セクション内のコントロールを順に処理
		foreach (GrapeCity.ActiveReports.SectionReportModel.ARControl ctrl in sec.Controls)
		{
			// TextBox の場合は背景を透過にする
			if (ctrl is TextBox)
			{
				TextBox tbx = (TextBox) ctrl;
				tbx.BackColor = System.Drawing.Color.Transparent;
			}

			// Label の場合は背景を透過にする
			if (ctrl is Label)
			{
				GrapeCity.ActiveReports.SectionReportModel.Label lbl = (Label) ctrl;
				lbl.BackColor = System.Drawing.Color.Transparent;
			}
		}
	}
}


/// <summary>
/// 指定フィールドの値を安全に文字列化して返します。
/// - フィールドが存在しない場合は "" を返す
/// - 値取得時に例外が発生した場合も "" を返す
/// - 値が null / DBNull の場合は "" を返す
/// - それ以外は ToString() して末尾空白を TrimEnd() した文字列を返す
/// ※帳票処理中の NullReference / FieldNotFound を避けるためのヘルパーです。
/// </summary>
/// <param name="fieldName">取得したいフィールド名</param>
/// <returns>安全化された文字列（取得不可の場合は ""）</returns>
private string SafeFieldStr(string fieldName)
{
	// レポートにこのフィールドが存在しない場合は空文字列を返す
	if (!HasField(fieldName)) return "";

	object result = null;

	// フィールドの値を取得を試みる。エラー（例: 実行時にフィールドが存在しない）場合は空文字列を返す
	try
	{
		result = rpt.Fields[fieldName].Value;
	}
	catch
	{
		return "";
	}

	// 値が null または DBNull の場合は空文字列を返し、そうでなければ文字列に変換して返す
	return (result == null || result == DBNull.Value) ? "" : result.ToString().TrimEnd();
}

/// <summary>
/// 指定したフィールド名が rpt.Fields に存在するかを判定します。
/// 実行時にフィールド未定義・参照エラーが起きても帳票処理を止めないため、例外は握りつぶして false を返します。
/// </summary>
/// <param name="fieldName">存在確認したいフィールド名</param>
/// <returns>
/// true : rpt / Fields が有効で、かつ指定フィールドが存在する  
/// false: rpt が null、Fields が null、または参照時に例外が発生した場合
/// </returns>
private bool HasField(string fieldName)
{
	try
	{
		return (rpt != null && rpt.Fields != null && rpt.Fields[fieldName] != null);
	}
	catch
	{
		return false;
	}
}]]></Script>
