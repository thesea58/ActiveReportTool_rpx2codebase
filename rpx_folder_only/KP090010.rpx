	/*if {帳票データ.予算コード}[ 3 TO 10 ] = '00000000' then Sum ({@当初予算額1},{@科目コード(款)} )
		else if {帳票データ.予算コード}[ 5 TO 10 ] = '000000' then Sum ({@当初予算額1},{@科目コード(項)} )
