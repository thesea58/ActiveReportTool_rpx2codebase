private Dictionary<string, decimal> totalGroup節_流用増減額1 = new Dictionary<string, decimal>();

public void Section3_Format()
{
	if(!CheckDataSource()) return;
	/*{@予算現額} -{帳票データ.累計執行額}
	*/
	this.Field17.Text =
		(TryDecimal(this.Field19.Value) - TryDecimal(rpt.Fields["累計執行額"].Value)).ToString("#,##0");
	
	/*if {帳票データ.累計執行額} = 0 or {@予算現額} = 0 then 0
		else {帳票データ.累計執行額}/{@予算現額}*100 */

	if (TryDecimal(rpt.Fields["累計執行額"].Value) == 0M || TryDecimal(this.Field19.Value) == 0M)
	{
		this.Field18.Value = 0;
	}
	else
	{
		this.Field18.Value =
			(TryDecimal(rpt.Fields["累計執行額"].Value) / TryDecimal(this.Field19.Value)) * 100;
	}
}


public void Section5_Format()
{
	if(!CheckDataSource()) return;
	
	#region 非表示
	this.Field1.Visible = rpt.Fields["見出区分"].Value.ToString().Contains("TIMESTAMPON");
	#endregion
	
	#region Formula [@タイムスタンプ]
	// カルチャの「言語-国/地域」を「日本語-日本」に設定します。
	System.Globalization.CultureInfo ci = new System.Globalization.CultureInfo("ja-JP");
	// 和暦を表すクラスです。
	System.Globalization.JapaneseCalendar jp = new System.Globalization.JapaneseCalendar();
	
	// 現在のカルチャで使用する暦を、和暦に設定します。
	ci.DateTimeFormat.Calendar = jp;
	// 「書式」「カルチャの書式情報」を使用し、文字列に変換します。
	this.Field1.Text = DateTime.Now.ToString("gg yy年MM月dd日 HH:mm:ss", ci);
	#endregion
	
}

/// <summary>
/// レポート開始時（ReportStart）に初期設定を行う。
/// - データソースの妥当性チェック
/// - 並び順（ソート）の適用
/// - CrossSectionBox の罫線設定（必要時のみ）
/// </summary>
public void ActiveReport_ReportStart()
{
	SetBgColorTransparentAllSections();
	
	if (CrossSectionBox1 != null)
		CrossSectionBox1.CloseBorder = true;
	
	if(!CheckDataSource()) return;
	ApplySort();

}

/// <summary>
/// object を decimal に変換するユーティリティ。
/// 変換に失敗した場合は 0 を返し、帳票計算中の例外を防ぐ。
/// </summary>
/// <param name="value">数値として扱いたい値。</param>
/// <returns>変換後の decimal。失敗時は 0。</returns>
decimal TryDecimal(object value)
{
	decimal outValue = 0M;
	if (decimal.TryParse(value.ToString(), out outValue))
	{
		return outValue;
	}
	else
	{
		return 0M;
	}
}

/// <summary>
/// レポートのデータソースに対して、Crystal Reports 側の並び順に近い形でソートを適用する。
/// 予算コードから科目コードの階層キー（款/項/目/節）を生成し、体系区分→階層→予算コードの順で並べ替える。
/// </summary>
private void ApplySort()
{
	
	System.Data.DataTable dt = rpt.DataSource as System.Data.DataTable;
	if (!dt.Columns.Contains("予算コード")) return; 
	
	AddCol(dt, "科目コード_款", typeof(string));
	AddCol(dt, "科目コード_項", typeof(string));
	AddCol(dt, "科目コード_目", typeof(string));
	AddCol(dt, "科目コード_節", typeof(string));
	AddCol(dt, "科目コード_細", typeof(string));

	
	//不使用
	AddCol(dt, "執行累計1_temp", typeof(string));
	AddCol(dt, "当月執行額1_temp", typeof(string));
	AddCol(dt, "当初予算額1_temp", typeof(string));
	AddCol(dt, "補正予算額1_temp", typeof(string));
	
	AddCol(dt, "予備費支出額1_temp", typeof(string));
	AddCol(dt, "流用増減額1_temp", typeof(string));


	for (int r = 0; r < dt.Rows.Count; r++)
	{
		string 予算コード_temp = Convert.ToString(dt.Rows[r]["予算コード"]);
		//{帳票データ.予算コード}[ 1 TO 2 ]
		dt.Rows[r]["科目コード_款"] = GetCrystalSubstring(予算コード_temp, 1, 2);
		//{帳票データ.予算コード}[ 1 TO 4 ]
		dt.Rows[r]["科目コード_項"] = GetCrystalSubstring(予算コード_temp, 1, 4);
		//{帳票データ.予算コード}[ 1 TO 6 ]
		dt.Rows[r]["科目コード_目"] = GetCrystalSubstring(予算コード_temp, 1, 6);
		//{帳票データ.予算コード}[ 1 TO 8 ]
		dt.Rows[r]["科目コード_節"] = GetCrystalSubstring(予算コード_temp, 1, 8);
		//{帳票データ.予算コード}[ 1 TO 10 ]
		dt.Rows[r]["科目コード_細"] = GetCrystalSubstring(予算コード_temp, 1, 10);
		
		//不使用 
		/*if {帳票データ.予算サイン} ='1'  then {帳票データ.累計執行額}
		else  0
		*/
		dt.Rows[r]["執行累計1_temp"] = Convert.ToString(dt.Rows[r]["予算サイン"]) == "1" ? Convert.ToString(dt.Rows[r]["累計執行額"]) : "0";
		/*if {帳票データ.予算サイン} ='1'  then {帳票データ.当月執行額}
 		else  0
		*/
		dt.Rows[r]["当月執行額1_temp"] = Convert.ToString(dt.Rows[r]["予算サイン"]) == "1" ? Convert.ToString(dt.Rows[r]["当月執行額"]) : "0";
		/*if {帳票データ.予算サイン} ='1'  then {帳票データ.当初予算額}
 		else  0
		*/
		dt.Rows[r]["当初予算額1_temp"] = Convert.ToString(dt.Rows[r]["予算サイン"]) == "1" ? Convert.ToString(dt.Rows[r]["当初予算額"]) : "0";
		/*if {帳票データ.予算サイン} = '1' then{帳票データ.補正予算額}
 		else 0
		*/
		dt.Rows[r]["補正予算額1_temp"] = Convert.ToString(dt.Rows[r]["予算サイン"]) == "1" ? Convert.ToString(dt.Rows[r]["補正予算額"]) : "0";
		/*if {帳票データ.予算サイン} = '1' then{帳票データ.予備費支出額}
		 else 0
		*/
		dt.Rows[r]["予備費支出額1_temp"] = Convert.ToString(dt.Rows[r]["予算サイン"]) == "1" ? Convert.ToString(dt.Rows[r]["予備費支出額"]) : "0";
		/*if {帳票データ.予算サイン} = '1' then{帳票データ.流用増減額}
 		else 0
		*/
		dt.Rows[r]["流用増減額1_temp"] = Convert.ToString(dt.Rows[r]["予算サイン"]) == "1" ? Convert.ToString(dt.Rows[r]["流用増減額"]) : "0";
		//
	}

	var dv2 = new System.Data.DataView(dt);
	dv2.Sort = "体系区分 ASC, 科目コード_款 ASC, 科目コード_項 ASC, 科目コード_目 ASC, 科目コード_節 ASC, 予算コード ASC";
	
	dt = dv2.ToTable();
	rpt.DataSource = dt;
	rpt.DataMember = null;
	/*
	if {帳票データ.予算コード}[ 3 TO 10 ] = '00000000' then Sum({@執行累計1},{@科目コード(款)})
		else if {帳票データ.予算コード}[ 5 TO 10 ] = '000000' then Sum({@執行累計1},{@科目コード(項)})
		ELSE if {帳票データ.予算コード}[ 7 TO 10 ] = '0000' then Sum({@執行累計1},{@科目コード(目)})
		ELSE if {帳票データ.予算コード}[ 9 TO 10 ] = '00' then Sum({@執行累計1},{@科目コード(節)})
	*/
	this.totalGroup款_執行累計1 =
		dt.AsEnumerable()
		.GroupBy(r => Convert.ToString(r["体系区分"]) + "|" + Convert.ToString(r["科目コード_款"]))
		.ToDictionary(
		g => g.Key,
		g => g.Where(r => GetCrystalSubstring(Convert.ToString(r["予算コード"]), 3, 10) == "00000000")
		.Sum(r => Convert.ToDecimal(r["執行累計1_temp"]))
		);
	this.totalGroup項_執行累計1 =
		dt.AsEnumerable()
		.GroupBy(r => Convert.ToString(r["体系区分"]) + "|" + Convert.ToString(r["科目コード_款"])
		+ "|" + Convert.ToString(r["科目コード_項"]))
		.ToDictionary(
		g => g.Key,
		g => g.Where(r => GetCrystalSubstring(Convert.ToString(r["予算コード"]), 5, 10) == "000000")
		.Sum(r => Convert.ToDecimal(r["執行累計1_temp"]))
		);
	this.totalGroup目_執行累計1 =
		dt.AsEnumerable()
		.GroupBy(r => Convert.ToString(r["体系区分"]) + "|" + Convert.ToString(r["科目コード_款"])
		+ "|" + Convert.ToString(r["科目コード_項"]) + "|" + Convert.ToString(r["科目コード_目"]))
		.ToDictionary(
		g => g.Key,
		g => g.Where(r => GetCrystalSubstring(Convert.ToString(r["予算コード"]), 7, 10) == "0000")
		.Sum(r => Convert.ToDecimal(r["執行累計1_temp"]))
		);
	this.totalGroup節_執行累計1 =
		dt.AsEnumerable()
		.GroupBy(r => Convert.ToString(r["体系区分"]) + "|" + Convert.ToString(r["科目コード_款"])
					+ "|" + Convert.ToString(r["科目コード_項"])+ "|" + Convert.ToString(r["科目コード_目"])
					+ "|" + Convert.ToString(r["科目コード_節"]))
		.ToDictionary(
		g => g.Key,
		g => g.Where(r => GetCrystalSubstring(Convert.ToString(r["予算コード"]), 9, 10) == "00")
		.Sum(r => Convert.ToDecimal(r["執行累計1_temp"]))
		);
	
	/* if {帳票データ.予算コード}[ 3 TO 10 ] = '00000000' then Sum ({@当月執行額1},{@科目コード(款)} )
		else if {帳票データ.予算コード}[ 5 TO 10 ] = '000000' then Sum ({@当月執行額1},{@科目コード(項)} )
		ELSE if {帳票データ.予算コード}[ 7 TO 10 ] = '0000' then Sum ({@当月執行額1},{@科目コード(目)} )
		ELSE if {帳票データ.予算コード}[ 9 TO 10 ] = '00' then Sum ({@当月執行額1},{@科目コード(節)} )
	*/
