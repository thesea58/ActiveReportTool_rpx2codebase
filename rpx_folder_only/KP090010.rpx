		.ToDictionary(
		g => g.Key,
		g => g.Where(r => GetCrystalSubstring(Convert.ToString(r["予算コード"]), 5, 10) == "000000")
		.Sum(r => Convert.ToDecimal(r["流用増減額1_temp"]))
		);
	
	this.totalGroup目_流用増減額1 =
		dt.AsEnumerable()
		.GroupBy(r => Convert.ToString(r["体系区分"]) + "|" + Convert.ToString(r["科目コード_款"])
		+ "|" + Convert.ToString(r["科目コード_項"]) + "|" + Convert.ToString(r["科目コード_目"]))
		.ToDictionary(
		g => g.Key,
		g => g.Where(r => GetCrystalSubstring(Convert.ToString(r["予算コード"]), 7, 10) == "0000")
		.Sum(r => Convert.ToDecimal(r["流用増減額1_temp"]))
		);
	
	this.totalGroup節_流用増減額1 =
		dt.AsEnumerable()
		.GroupBy(r => Convert.ToString(r["体系区分"]) + "|" + Convert.ToString(r["科目コード_款"])
		+ "|" + Convert.ToString(r["科目コード_項"]) + "|" + Convert.ToString(r["科目コード_目"])
		+ "|" + Convert.ToString(r["科目コード_節"]))
		.ToDictionary(
		g => g.Key,
		g => g.Where(r => GetCrystalSubstring(Convert.ToString(r["予算コード"]), 9, 10) == "00")
		.Sum(r => Convert.ToDecimal(r["流用増減額1_temp"]))
		);
	
}

/// <summary>
/// rpt.DataSource が存在し、System.Data.DataTable として有効か確認
/// </summary>
private bool CheckDataSource()
{
	// ブロック確認: DataSource が割り当てられているか（null でないか）を確認
	if (rpt.DataSource == null)
	{
		return false;
	}

	// ブロック確認: DataSource を DataTable にキャストし、キャストの成功を確認
	System.Data.DataTable dt = rpt.DataSource as System.Data.DataTable;
	if (dt == null)
	{
		return false;
	}

	return true;
}

/// <summary>
/// DataTable に指定した列が存在しない場合のみ、新しい列を追加する。
/// 既存列がある場合は何もしない（重複追加による例外回避）。
/// </summary>
/// <param name="dt">対象の DataTable。</param>
/// <param name="colName">追加する列名。</param>
/// <param name="type">列のデータ型。</param>
private void AddCol(System.Data.DataTable dt, string colName, System.Type type)
{
	if (!dt.Columns.Contains(colName))
		dt.Columns.Add(new System.Data.DataColumn(colName, type));
}

/// <summary>
/// 入力文字列からstart〜endまで（終端含む）の部分文字列を返す。CrystalReportのメソッドと同様（1-based）
/// </summary>
/// <param name="input">ソース文字列。</param>
/// <param name="start">開始インデックス（1-based）。</param>
/// <param name="end">終了インデックス（1-based、終端含む）。</param>
/// <returns>該当する部分文字列。入力無効かstartが範囲外なら空文字を返す。</returns>
private string GetCrystalSubstring(string input, int start, int end)
{
	// 0ベースに変換する
	start--;
	end--;
	// 入力チェック: inputがnull/empty、またはstartが文字列長を超える場合は空文字を返す
	if (string.IsNullOrEmpty(input) || start >= input.Length)
	{
		return "";
	}

	// 計算ブロック: 取得する長さを決定する。取得長を残り文字数を超えないようにクランプする。
	int length = Math.Min(end - start + 1, input.Length - start);
    
	// 結果取得ブロック: 計算済みの長さで start から substring を返す
	return input.Substring(start, length);
}

// rpt 内のすべてのセクションに対してテキスト系コントロールの背景色を透過に設定する
private void SetBgColorTransparentAllSections()
{
	// 全セクションを順に処理
	foreach (GrapeCity.ActiveReports.SectionReportModel.Section sec in rpt.Sections)
	{
		// セクション内のコントロールを順に処理
		foreach (GrapeCity.ActiveReports.SectionReportModel.ARControl ctrl in sec.Controls)
		{
			// TextBox の場合は背景を透過にする
			if (ctrl is TextBox)
			{
				TextBox tbx = (TextBox) ctrl;
				tbx.BackColor = System.Drawing.Color.Transparent;
			}

			// Label の場合は背景を透過にする
			if (ctrl is Label)
			{
				GrapeCity.ActiveReports.SectionReportModel.Label lbl = (Label) ctrl;
				lbl.BackColor = System.Drawing.Color.Transparent;
			}
		}
	}
}


public void Section17_Format()
{
	var key = Convert.ToString(rpt.Fields["体系区分"].Value) + "|" + Convert.ToString(rpt.Fields["科目コード_款"].Value);
	string yosanCode = Convert.ToString(rpt.Fields["予算コード"].Value);
	if (GetCrystalSubstring(yosanCode,3,10) == "00000000")
	{
		rpt.CalculatedFields["執行累計_temp"].Value = this.totalGroup款_執行累計1[key];
		rpt.CalculatedFields["補正予算額_temp"].Value = this.totalGroup款_補正予算額1[key];
		rpt.CalculatedFields["当初予算額_temp"].Value = this.totalGroup款_当初予算額1[key];
		rpt.CalculatedFields["当月執行額_temp"].Value = this.totalGroup款_当月執行額1[key];	
		rpt.CalculatedFields["予備費支出額_temp"].Value = this.totalGroup款_予備費支出額1[key];
		rpt.CalculatedFields["流用増減額_temp"].Value = this.totalGroup款_流用増減額1[key];	
	}
	else
	{
		/*ELSE {@執行累計1}
		ELSE {@当月執行額1}
		ELSE {@当初予算額1}
		ELSE {@補正予算額1}
		ELSE {@予備費支出額1}
		ELSE {@流用増減額1}
		*/
		rpt.CalculatedFields["執行累計_temp"].Value = rpt.Fields["執行累計1_temp"].Value;
		rpt.CalculatedFields["当月執行額_temp"].Value = rpt.Fields["当月執行額1_temp"].Value;
		rpt.CalculatedFields["当初予算額_temp"].Value = rpt.Fields["当初予算額1_temp"].Value;
		rpt.CalculatedFields["補正予算額_temp"].Value = rpt.Fields["補正予算額1_temp"].Value;
		rpt.CalculatedFields["予備費支出額_temp"].Value = rpt.Fields["予備費支出額1_temp"].Value;
		rpt.CalculatedFields["流用増減額_temp"].Value = rpt.Fields["流用増減額1_temp"].Value;
	}
}

