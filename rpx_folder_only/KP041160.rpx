    <Field Name="貸方予算コード款" Formula="=予算コード.Substring( 0, 2)" FieldType="None" />
    <Field Name="貸方予算コード項" Formula="=予算コード.Substring( 2, 2) " FieldType="None" />
    <Field Name="貸方予算コード目" Formula="=予算コード.Substring( 4, 2) " FieldType="None" />
    <Field Name="貸方予算コード節" Formula="=予算コード.Substring( 6, 2) " FieldType="None" />
