    <Field Name="借方税コード項" Formula="=借方税科目コード.Substring( 2, 2) " FieldType="None" />
    <Field Name="借方税コード目" Formula="=借方税科目コード.Substring( 4, 2) " FieldType="None" />
    <Field Name="借方税コード節" Formula="=借方税科目コード.Substring( 6, 2) " FieldType="None" />
    <Field Name="貸方税コード款" Formula="=貸方税科目コード.Substring( 0, 2) " FieldType="None" />
    <Field Name="貸方税コード項" Formula="=貸方税科目コード.Substring( 2, 2) " FieldType="None" />
    <Field Name="貸方税コード目" Formula="=貸方税科目コード.Substring( 4, 2) " FieldType="None" />
    <Field Name="貸方税コード節" Formula="=貸方税科目コード.Substring( 6, 2) " FieldType="None" />
    <Field Name="予算残額3" Formula="=借方予算現額 - 借方執行額" FieldType="None" />
    <Field Name="予算残額4" Formula="=予算現額 - 執行額 " FieldType="None" />
    <Field Name="借方予算現額" Formula="=(借方予算コード == &quot;&quot;)  ? &quot;&quot; : ((借方予算コード款_cal == &quot;99&quot;)  ? &quot;&quot; : 借方予算現額.ToString(&quot;F0&quot;))" FieldType="None" />
    <Field Name="借方執行累計額" Formula="=(借方予算コード == &quot;&quot;)  ? &quot;&quot; : ((借方予算コード款_cal == &quot;99&quot;)  ? &quot;&quot; : 借方執行額.ToString(&quot;F0&quot;))" FieldType="None" />
    <Field Name="借方予算残額" FieldType="None" />
    <Field Name="貸方予算現額" Formula="=(予算コード == &quot;&quot;)  ? &quot;&quot;  : ((貸方予算コード款 == &quot;99&quot;)  ? &quot;&quot;  : (予算現額.ToString(&quot;F0&quot;)))" FieldType="None" />
    <Field Name="貸方執行累計額" Formula="=(予算コード == &quot;&quot;)  ? &quot;&quot;  : ((貸方予算コード款 == &quot;99&quot;)  ? &quot;&quot;  : (執行額.ToString(&quot;F0&quot;)))" FieldType="None" />
    <Field Name="貸方予算残額" Formula="=if {伝票データ.予算コード} = &quot;&quot; &#xD;&#xA;    then &quot;&quot;&#xD;&#xA;    else if {@貸方予算コード款} = &quot;99&quot; &#xD;&#xA;    then &quot;&quot;&#xD;&#xA;    else ToText (ToNumber ({@貸方予算現額}) - ToNumber ({@貸方執行累計額}), 0)&#xD;&#xA;" FieldType="None" />
    <Field Name="借方税区分名称" Formula="=(借方税区分 == &quot;1&quot; ||  借方税区分 == &quot;2&quot;) ? &quot;課税&quot; :  ((借方税区分 == &quot;0&quot; ||  借方税区分 == &quot;&quot;) ? &quot;無&quot; :  借方税区分名称 )" FieldType="None" />
    <Field Name="貸方税区分名称" Formula="=(税区分 == &quot;1&quot; ||  税区分 == &quot;2&quot;) ? &quot;課税&quot; : ((税区分 == &quot;0&quot; ||  税区分 == &quot;&quot;) ? &quot;無&quot; :  税区分名称)" FieldType="None" />
    <Field Name="所属コード名称１" Formula="=(Length (借方所属コード名称) &lt;= 7) ? 借方所属コード名称 : 借方所属コード名称.Substring(6, 4)" FieldType="None" />
    <Field Name="所属コード名称Cal" Formula="=(Length (借方所属コード名称) &gt; 7) ? 借方所属コード名称.Substring(0 , 6) : &quot;&quot;" FieldType="None" />
    <Field Name="特別貸方予算款名称" Formula="=(貸方予算コード款 == &quot;99&quot;) ? &quot;&quot; :予算款名称" FieldType="None" />
    <Field Name="特別貸方予算項名称" Formula="=(貸方予算コード款 == &quot;99&quot;) ? &quot;&quot; :予算項名称 " FieldType="None" />
    <Field Name="特別貸方予算目名称" Formula="=(貸方予算コード款 == &quot;99&quot;) ? &quot;&quot; :予算目名称" FieldType="None" />
    <Field Name="特別貸方予算節名称" Formula="=(貸方予算コード款 == &quot;99&quot;) ? &quot;&quot; :予算節名称" FieldType="None" />
    <Field Name="特別貸方予算細名称" Formula="=(貸方予算コード款 == &quot;99&quot;) ? &quot;&quot; :予算細名称" FieldType="None" />
    <Field Name="特別借方予算款名称" Formula="=(借方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 借方予算款名称 " FieldType="None" />
    <Field Name="特別借方予算項名称" Formula="=(借方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 借方予算項名称 " FieldType="None" />
    <Field Name="特別借方予算目名称" Formula="=(借方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 借方予算目名称 " FieldType="None" />
    <Field Name="特別借方予算節名称" Formula="=(借方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 借方予算節名称" FieldType="None" />
    <Field Name="特別借方予算細名称" Formula="=(借方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 借方予算細名称" FieldType="None" />
    <Field Name="借方予算款" Formula="=(借方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 借方予算コード.Substring( 0, 2)" FieldType="None" />
    <Field Name="借方予算項" Formula="=(借方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 借方予算コード.Substring( 2, 2)" FieldType="None" />
    <Field Name="借方予算目" Formula="=(借方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 借方予算コード.Substring( 4, 2)" FieldType="None" />
    <Field Name="借方予算節" Formula="=(借方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 借方予算コード.Substring( 6, 2)" FieldType="None" />
    <Field Name="借方予算細" Formula="=(借方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 借方予算コード.Substring( 8, 2)" FieldType="None" />
    <Field Name="貸方予算款" Formula="=(貸方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 予算コード.Substring(0, 2)" FieldType="None" />
    <Field Name="貸方予算項" Formula="=(貸方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 予算コード.Substring(2, 2)" FieldType="None" />
    <Field Name="貸方予算目" Formula="=(貸方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 予算コード.Substring(4, 2) " FieldType="None" />
    <Field Name="貸方予算節" Formula="=(貸方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 予算コード.Substring(6, 2) " FieldType="None" />
    <Field Name="貸方予算細" Formula="=(貸方予算コード款 == &quot;99&quot;) ? &quot;&quot; : 予算コード.Substring(8, 2) " FieldType="None" />
    <Field Name="決裁１" Formula="=(伝票データ.決裁額} &gt; 0) ? &quot;&quot; : &quot;*&quot;&#xD;&#xA;" FieldType="None" />
    <Field Name="決裁２" Formula="=//if({伝票データ.決裁額}&gt;500000)&#xD;&#xA;//then&#xD;&#xA;//    &quot;&quot;&#xD;&#xA;//else&#xD;&#xA;//    &quot;*&quot;&#xD;&#xA;//&#xD;&#xA;&#xD;&#xA; &quot;*&quot;" FieldType="None" />
    <Field Name="決裁３" Formula="=//if({伝票データ.決裁額}&gt;1000000)&#xD;&#xA;//then&#xD;&#xA;//    &quot;&quot;&#xD;&#xA;//else&#xD;&#xA;//    &quot;*&quot;&#xD;&#xA;&#xD;&#xA; &quot;*&quot;" FieldType="None" />
    <Field Name="決裁４" Formula="=//if({伝票データ.決裁額}&gt;2000000)&#xD;&#xA;//then&#xD;&#xA;//    &quot;&quot;&#xD;&#xA;//else&#xD;&#xA;//    &quot;*&quot;&#xD;&#xA;&#xD;&#xA; &quot;*&quot;" FieldType="None" />
    <Field Name="決裁５" Formula="=//if({伝票データ.決裁額}&gt;5000000)&#xD;&#xA;//then&#xD;&#xA;//    &quot;&quot;&#xD;&#xA;//else&#xD;&#xA;//    &quot;*&quot;&#xD;&#xA;&#xD;&#xA;&quot;*&quot;&#xD;&#xA;" FieldType="None" />
    <Field Name="決裁額Cal" Formula="=(決裁額&gt;0) ? 決裁額 : 決裁額 * -1 " FieldType="None" />
    <Field Name="消費税額Cal" Formula="=0" FieldType="None" />
    <Field Name="決裁3" Formula="=(決裁額 &lt; 999999999999) ? &quot;＊&quot; : &quot;&quot; " FieldType="None" />
    <Field Name="決裁2" Formula="=(決裁額 &lt; 13000000) ? &quot;＊&quot; : &quot;&quot; " FieldType="None" />
    <Field Name="決裁1" Formula="=(決裁額 &lt; 1300000) ? &quot;＊&quot; : &quot;&quot; " FieldType="None" />
    <Field Name="主幹表示" Formula="=(年度==&quot;令和04年度&quot;) ? &quot;副主幹&quot; : &quot;主幹&quot; " FieldType="None" />
  </CalculatedFields>
  <Script><![CDATA[public void ReportHeaderSection1_Format()
{
	#region set BackColor transparent
	SetBgColerTransparent(DetailSection1_DetailSection2_DetailSection3);
	#endregion
}
// セクション内のテキストボックスの背景色を透明に設定する
public void SetBgColerTransparent(GrapeCity.ActiveReports.SectionReportModel.Section sec)
{
	foreach (GrapeCity.ActiveReports.SectionReportModel.ARControl ctrl in sec.Controls)
	{
		if (ctrl is TextBox)
		{
			TextBox tbx = (TextBox) ctrl;
			tbx.BackColor = System.Drawing.Color.Transparent; 
		}
		if (ctrl is Label )
		{
			GrapeCity.ActiveReports.SectionReportModel.Label lbl = (Label) ctrl;
			lbl.BackColor = System.Drawing.Color.Transparent;
		}
	}
}
public void DetailSection1_DetailSection2_DetailSection3_Format()
{
	税区分名称1.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	貸方税科目節名称1.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	
	特別貸方予算款名称1.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	特別貸方予算項名称1.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	特別貸方予算目名称1.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	特別貸方予算節名称1.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	特別貸方予算細名称1.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	貸方予算款2.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	貸方予算項2.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	貸方予算目2.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	貸方予算節2.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	貸方予算細2.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");

	貸方執行累計額1.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	貸方予算現額1.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	貸方予算残額1.Visible = (rpt.Fields["現金主義サイン"].Value.ToString() == "1");
	
	if (Convert.ToInt64(rpt.Fields["決裁額"].Value) < 0){
		決裁額2.BackColor = System.Drawing.Color.Silver;
	}
	else{
		決裁額2.BackColor = System.Drawing.Color.Transparent;
	}
	/*
	if {伝票データ.予算コード} = "" 
		then ""
	else if {@貸方予算コード款} = "99" 
    then ""
	else ToText (ToNumber ({@貸方予算現額}) - ToNumber ({@貸方執行累計額}), 0)
	*/
	
	string 貸方予算コード款 = rpt.Fields["予算コード"].Value.ToString().Substring(0, 2);
	decimal 貸方予算現額 = Convert.ToDecimal(rpt.CalculatedFields["貸方予算現額"].Value);
	decimal 貸方執行累計額 = Convert.ToDecimal(rpt.CalculatedFields["貸方執行累計額"].Value);
//	System.Windows.Forms.MessageBox.Show(貸方予算現額.ToString() + "-" + 貸方執行累計額.ToString());
	if (rpt.Fields["予算コード"].Value.ToString() == "")
	{
		貸方予算残額1.Text = "";
	}
	else if(貸方予算コード款 == "99")
	{
		貸方予算残額1.Text = "";
	}
	else 
	{
		decimal kq = 貸方予算現額 - 貸方執行累計額;
		貸方予算残額1.Value = kq;
	}
}


public void DetailSection1_DetailSection2_DetailSection3_AfterPrint()
{

}


public void PageHeaderSection1_Format()
{

}


