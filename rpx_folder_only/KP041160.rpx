    <Field Name="予算残額" Formula="=予算現額 - 執行額 " FieldType="None" />
    <Field Name="金融機関" Formula="=銀行番号 + &quot;-&quot; +  支店番号 + &quot;  &quot; + 金融機関名称 " FieldType="None" />
