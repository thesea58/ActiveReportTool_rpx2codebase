    <Field Name="借方コード款2" Formula="=(借方科目コード.Length &lt; 0+2) ? &quot;&quot; : 借方科目コード.Substring(0, 2)" FieldType="None" />
    <Field Name="借方コード項2" Formula="=(借方科目コード.Length &lt; 2+2) ? &quot;&quot; : 借方科目コード.Substring(2, 2)" FieldType="None" />
    <Field Name="借方コード目2" Formula="=(借方科目コード.Length &lt; 4+2) ? &quot;&quot; : 借方科目コード.Substring(4, 2)" FieldType="None" />
    <Field Name="貸方コード款2" Formula="=(貸方科目コード.Length &lt; 0+2) ? &quot;&quot; : 貸方科目コード.Substring(0, 2)" FieldType="None" />
    <Field Name="貸方コード項2" Formula="=(貸方科目コード.Length &lt; 2+2) ? &quot;&quot; : 貸方科目コード.Substring(2, 2)" FieldType="None" />
    <Field Name="貸方コード目2" Formula="=(貸方科目コード.Length &lt; 4+2) ? &quot;&quot; : 貸方科目コード.Substring(4, 2)" FieldType="None" />
    <Field Name="貸方コード節2" Formula="=(貸方科目コード.Length &lt; 6+2) ? &quot;&quot; : 貸方科目コード.Substring(6, 2)" FieldType="None" />
    <Field Name="借方コード節2" Formula="=(借方科目コード.Length &lt; 6+2) ? &quot;&quot; : 借方科目コード.Substring(6, 2)" FieldType="None" />
    <Field Name="借方予算コード款" Formula="=借方予算コード.Substring( 0, 2) " FieldType="None" />
