    <Field Name="貸方予算現額_Cal" Formula="= 貸方予算コード == &quot;&quot; ?  &quot;&quot; : (貸方予算現額 == 0 ? &quot;&quot; : 貸方予算現額.ToString(&quot;N0&quot;))" FieldType="None" />
