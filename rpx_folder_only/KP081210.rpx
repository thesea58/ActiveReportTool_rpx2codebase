  <Script><![CDATA[
public void ActiveReport_ReportStart()
{
	// rpt 内のすべてのセクションに対してテキスト系コントロールの背景色を透過に設定する
	SetBgColorTransparentAllSections();
}

public bool ActiveReport_FetchData(bool eof)
{
	try
	{
		if (eof) return eof;
		
		
		/*CR Formula:借方予算款コード
		={伝票データ.借方予算コード}[1 TO 2]
		*/
		rpt.CalculatedFields["借方予算款コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["借方予算コード"].Value), 1, 2);
		
		/*CR Formula:借方予算項コード
		={伝票データ.借方予算コード}[3 TO 4]
		*/
		rpt.CalculatedFields["借方予算項コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["借方予算コード"].Value), 3, 4);
		
		/*CR Formula:借方予算目コード
		={伝票データ.借方予算コード}[5 TO 6]
		*/
		rpt.CalculatedFields["借方予算目コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["借方予算コード"].Value), 5, 6);
		
		/*CR Formula:借方予算節コード
		={伝票データ.借方予算コード}[7 TO 8]
		*/
		rpt.CalculatedFields["借方予算節コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["借方予算コード"].Value), 7, 8);
		
		/*CR Formula:借方予算細コード
		={伝票データ.借方予算コード}[9 TO 10]
		*/
		rpt.CalculatedFields["借方予算細コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["借方予算コード"].Value), 9, 10);
		
        /*CR Formula:借方款コード
        ={伝票データ.借方科目コード}[1 TO 2]
        */
		rpt.CalculatedFields["借方款コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["借方科目コード"].Value), 1, 2);
        
        /*CR Formula:借方項コード
        ={伝票データ.借方科目コード}[3 TO 4]
        */
		rpt.CalculatedFields["借方項コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["借方科目コード"].Value), 3, 4);
        
        /*CR Formula:借方目コード
        ={伝票データ.借方科目コード}[5 TO 6]
        */
		rpt.CalculatedFields["借方目コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["借方科目コード"].Value), 5, 6);
        
        /*CR Formula:借方節コード
        ={伝票データ.借方科目コード}[7 TO 8]
        */
		rpt.CalculatedFields["借方節コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["借方科目コード"].Value), 7, 8);
        
        /*CR Formula:貸方款コード
        ={伝票データ.貸方科目コード}[1 TO 2]
        */
		rpt.CalculatedFields["貸方款コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["貸方科目コード"].Value), 1, 2);
        
        /*CR Formula:貸方項コード
        ={伝票データ.貸方科目コード}[3 TO 4]
        */
		rpt.CalculatedFields["貸方項コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["貸方科目コード"].Value), 3, 4);
        
        /*CR Formula:貸方目コード
        ={伝票データ.貸方科目コード}[5 TO 6]
        */
		rpt.CalculatedFields["貸方目コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["貸方科目コード"].Value), 5, 6);
        
        /*CR Formula:貸方節コード
        ={伝票データ.貸方科目コード}[7 TO 8]
        */
		rpt.CalculatedFields["貸方節コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["貸方科目コード"].Value), 7, 8);
        
        /*CR Formula:貸方予算款コード
        ={伝票データ.貸方予算コード}[1 TO 2]
        */
		rpt.CalculatedFields["貸方予算款コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["貸方予算コード"].Value), 1, 2);
        
        /*CR Formula:貸方予算項コード
        ={伝票データ.貸方予算コード}[3 TO 4]
        */
		rpt.CalculatedFields["貸方予算項コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["貸方予算コード"].Value), 3, 4);
        
        /*CR Formula:貸方予算目コード
        ={伝票データ.貸方予算コード}[5 TO 6]
        */
		rpt.CalculatedFields["貸方予算目コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["貸方予算コード"].Value), 5, 6);
        
        /*CR Formula:貸方予算節コード
        ={伝票データ.貸方予算コード}[7 TO 8]
        */
		rpt.CalculatedFields["貸方予算節コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["貸方予算コード"].Value), 7, 8);
        
        /*CR Formula:貸方予算細コード
        ={伝票データ.貸方予算コード}[9 TO 10]
        */
		rpt.CalculatedFields["貸方予算細コード"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["貸方予算コード"].Value), 9, 10);
		return eof;
	}
	catch{
		return true;
		throw;	
	}
}
/// <summary>
/// 入力文字列からstart〜endまで（終端含む）の部分文字列を返す。CrystalReportのメソッドと同様（1-based）
/// </summary>
/// <param name="input">ソース文字列。</param>
/// <param name="start">開始インデックス（1-based）。</param>
/// <param name="end">終了インデックス（1-based、終端含む）。</param>
/// <returns>該当する部分文字列。入力無効かstartが範囲外なら空文字を返す。</returns>
private string GetCrystalSubstring(string input, int start, int end)
{
	// 0ベースに変換する
	start--;
	end--;
	// 入力チェック: inputがnull/empty、またはstartが文字列長を超える場合は空文字を返す
	if (string.IsNullOrEmpty(input) || start >= input.Length)
	{
		return "";
	}

	// 計算ブロック: 取得する長さを決定する。取得長を残り文字数を超えないようにクランプする。
	int length = Math.Min(end - start + 1, input.Length - start);
    
	// 結果取得ブロック: 計算済みの長さで start から substring を返す
	return input.Substring(start, length);
}

/// <summary>
/// 指定セクション配下の TextBox / Label の背景色を Transparent に設定する。
/// （背景塗りつぶしによるレイアウト崩れ・重ね表示の見えにくさを防ぐ目的）
/// </summary>
/// <param name="sec">対象セクション。</param>
// rpt 内のすべてのセクションに対してテキスト系コントロールの背景色を透過に設定する
private void SetBgColorTransparentAllSections()
{
	// 全セクションを順に処理
	foreach (GrapeCity.ActiveReports.SectionReportModel.Section sec in rpt.Sections)
	{
		// セクション内のコントロールを順に処理
		foreach (GrapeCity.ActiveReports.SectionReportModel.ARControl ctrl in sec.Controls)
		{
			// TextBox の場合は背景を透過にする
			if (ctrl is TextBox)
			{
				TextBox tbx = (TextBox) ctrl;
				tbx.BackColor = System.Drawing.Color.Transparent;
			}

			// Label の場合は背景を透過にする
			if (ctrl is Label)
			{
				GrapeCity.ActiveReports.SectionReportModel.Label lbl = (Label) ctrl;
				lbl.BackColor = System.Drawing.Color.Transparent;
			}
		}
	}
}

/// <summary>
/// Section3 の Format イベント。
/// - 背景色の透明化
/// - バーコード有無／決裁欄パターンに応じた表示切替
/// - 予算残額（借方／貸方）の計算・表示
/// </summary>
public void Section3_Format()
{
	
	#region 非表示
	this.消込用1.Visible = rpt.Fields["伝票バーコード"].Value.ToString() != "";
	Text17.Visible = rpt.Fields["伝票バーコード"].Value.ToString() != "";
	this.PG1.Visible = rpt.Fields["PGバーコード"].Value.ToString() == "";

	決裁名称1.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 1);
	決裁名称2.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 2);
	決裁名称3.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 3);
	決裁名称4.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 4);
	決裁名称5.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 5);
	決裁名称6.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 6);
	決裁名称7.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 7);
	決裁名称8.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 8);
	決裁名称9.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 9);
	決裁名称10.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 10);
	決裁欄11.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 9);
	決裁欄12.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 8);
	決裁欄13.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 7);
	決裁欄14.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 6);
	決裁欄15.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 5);
	決裁欄18.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 2);
	決裁欄19.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 1);
	決裁欄7.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 8);
	決裁欄8.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 7);
	決裁欄9.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 6);
	決裁欄3.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 2);
	決裁欄１1.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 1);
	決裁欄10.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 10);
	決裁欄1.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 10);
	決裁欄2.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 9);
	決裁欄16.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 4);
	決裁欄17.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 3);
	決裁欄4.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 3);
	決裁欄5.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 4);
	決裁欄6.Visible = ((int) rpt.Fields["決裁欄枠パターン"].Value >= 5);
	
	#endregion

	#region  借方予算残額, 貸方予算残額
	
	if(rpt.DataSource != null) 
	{
		/*if if {伝票データ.借方予算コード} = '' 
		    then ''
		else if {伝票データ.借方予算現額} = 0
		    then ''
		    else ToText (ToNumber ({@借方予算現額}) - ToNumber ({@借方予算執行額}),0,',')

		*/
		if(rpt.Fields["借方予算コード"].Value.ToString() == "")
		{
			this.Field16.Text = "";
		}
		else if(rpt.Fields["借方予算現額"].Value.ToString() == "0")
		{
			this.Field16.Text = "";
		}
		
		else
		{
			this.Field16.Text = (TryDecimal(this.Field19.Value)
				- TryDecimal(this.Field21.Value)).ToString("N0");
		}
		
		/*	
			if {伝票データ.貸方予算コード} = '' 
			    then ''
			else if {伝票データ.貸方予算現額} = 0
			    then ''
			    else ToText (ToNumber ({@貸方予算現額}) - ToNumber ({@貸方予算執行額}),0,',')
		*/
		if(rpt.Fields["貸方予算コード"].Value.ToString() == "")
		{
			this.Field50.Text = "";
		}
		else if(rpt.Fields["貸方予算現額"].Value.ToString() == "0")
		{
			this.Field50.Text = "";
		}
		else
		{
			this.Field50.Text = (TryDecimal(this.Field20.Value)
				- TryDecimal(this.Field22.Value)).ToString("N0");
		}

	}

	#endregion

}

/// <summary>
/// object を decimal に安全変換するユーティリティ。
/// 変換できない場合は 0 を返す（帳票計算で例外を出さないため）。
/// </summary>
/// <param name="value">数値として扱いたい値。</param>
/// <returns>変換後の decimal。失敗時は 0。</returns>
decimal TryDecimal(object value)
{
	decimal outValue = 0M;
	if (decimal.TryParse(value.ToString(), out outValue))
	{
		return outValue;
	}
	else
	{
		return 0M;
	}
}
]]></Script>
