	this.決裁名称10.Visible = (int) rpt.Fields["決裁欄枠パターン"].Value >= 10;
	this.決裁欄1.Visible = (int) rpt.Fields["決裁欄枠パターン"].Value >= 10;
	this.決裁欄10.Visible = (int) rpt.Fields["決裁欄枠パターン"].Value >= 10;
	
	#endregion
	
	#region フロントの色
	// 決裁名称2
	// if { ヘッダデータ.決裁名称2} = "" then 1 else 0

	if (rpt.Fields["決裁名称2"].Value.ToString() == "")
	{
		this.決裁名称2.ForeColor = System.Drawing.Color.White;
	}
	else
	{
		this.決裁名称2.ForeColor = System.Drawing.Color.Black;
	}
	#endregion
	
	#region  TextAlignment 修正
	
	Field1.Alignment = TextAlignment.Right;
	Field2.Alignment = TextAlignment.Right;
	Field5.Alignment = TextAlignment.Right;

	#endregion
}


]]></Script>
