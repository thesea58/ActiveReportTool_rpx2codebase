  <CalculatedFields>
    <Field Name="税区分名称" Formula="= (税区分 == '1'|| 税区分 == '2') ? &quot;課税&quot; : &#xD;&#xA;税区分名称.Value" FieldType="None" />
    <Field Name="借方款コード" Formula="=借方科目コード.Substring(0,2)" FieldType="None" />
    <Field Name="借方項コード" Formula="=借方科目コード.Substring(2,2)" FieldType="None" />
    <Field Name="借方目コード" Formula="=借方科目コード.Substring(4,2)" FieldType="None" />
    <Field Name="借方節コード" Formula="=借方科目コード.Substring(6,2)" FieldType="None" />
    <Field Name="貸方款コード" Formula="=貸方科目コード.Substring(0,2)" FieldType="None" />
    <Field Name="貸方項コード" Formula="=貸方科目コード.Substring(2,2)" FieldType="None" />
    <Field Name="貸方目コード" Formula="=貸方科目コード.Substring(4,2)" FieldType="None" />
    <Field Name="貸方節コード" Formula="=貸方科目コード.Substring(6,2)" FieldType="None" />
    <Field Name="金融機関名称sub" Formula="=銀行番号 + &quot; - &quot; + 支店番号 + &quot;  &quot; + 金融機関名称" FieldType="None" />
    <Field Name="決裁欄" Formula="=&quot; &quot;" FieldType="None" />
    <Field Name="住所" Formula="= 住所1 + &quot;　&quot; + 住所2" FieldType="None" />
  </CalculatedFields>
  <Script><![CDATA[public void Section3_Format()
{
	#region set BackColor transparent

	foreach (GrapeCity.ActiveReports.SectionReportModel.ARControl ctrl in this.Section3.Controls)
	{
		if (ctrl is TextBox)
		{
			TextBox tbx = (TextBox) ctrl;
			tbx.BackColor = System.Drawing.Color.Transparent; 
		}
		if (ctrl is Label )
		{
			GrapeCity.ActiveReports.SectionReportModel.Label lbl = (Label) ctrl;
			lbl.BackColor = System.Drawing.Color.Transparent;
		}
	}
	#endregion
	
	#region 非表示
	this.消込用1.Visible = rpt.Fields["伝票バーコード"].Value.ToString() != "";
	this.Text21.Visible = rpt.Fields["伝票バーコード"].Value.ToString() != "";
