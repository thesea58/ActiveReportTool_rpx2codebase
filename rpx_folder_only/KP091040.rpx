  <CalculatedFields>
    <Field Name="見出し" Formula="= 体系区分 == &quot;4&quot; ? &quot;（ 収益的収入 ）&quot; : (体系区分 == &quot;5&quot; ? &quot;（ 収益的支出 ）&quot;: (体系区分 == &quot;6&quot; ? &quot;（ 資本的収入 ）&quot;: (体系区分 == &quot;7&quot; ? &quot;（ 資本的支出 ）&quot;: (体系区分 == &quot;8&quot; ? &quot;（ たな卸資産購入限度額 ）&quot;: (体系区分 = &quot;9&quot; ? &quot;（ 特別勘定 ）&quot;: &quot;&quot;)))))" FieldType="None" />
    <Field Name="所属表示" Formula="= 備考1" FieldType="None" />
    <Field Name="予算現額_Cal" Formula="= 当初予算額 + 補正予算額 + 流用増減額 + 予備費支出額 + 繰越予算額" FieldType="None" />
    <Field Name="科目コード_細" FieldType="None" />
    <Field Name="執行累計_temp" FieldType="None" />
    <Field Name="当月執行額_temp" FieldType="None" />
    <Field Name="当初予算額_temp" FieldType="None" />
    <Field Name="補正予算額_temp" FieldType="None" />
    <Field Name="予備費支出額_temp" FieldType="None" />
    <Field Name="流用増減額_temp" FieldType="None" />
    <Field Name="予算コード_Cal" Formula="= &quot;(&quot; + (System.String.IsNullOrEmpty(予算コード) ? &quot;&quot; : (予算コード.Length &lt; 1 ? &quot;&quot; : 予算コード.Substring(0, (予算コード.Length &gt;= 2 ? 2 : (予算コード.Length - 0))))) + &quot;-&quot; + (System.String.IsNullOrEmpty(予算コード) ? &quot;&quot; : (予算コード.Length &lt; 3 ? &quot;&quot; : 予算コード.Substring(2, (予算コード.Length &gt;= 4 ? 2 : (予算コード.Length - 2))))) + &quot;-&quot; + (System.String.IsNullOrEmpty(予算コード) ? &quot;&quot; : (予算コード.Length &lt; 5 ? &quot;&quot; : 予算コード.Substring(4, (予算コード.Length &gt;= 6 ? 2 : (予算コード.Length - 4))))) + &quot;-&quot; + (System.String.IsNullOrEmpty(予算コード) ? &quot;&quot; : (予算コード.Length &lt; 7 ? &quot;&quot; : 予算コード.Substring(6, (予算コード.Length &gt;= 8 ? 2 : (予算コード.Length - 6))))) + &quot;-&quot; + (System.String.IsNullOrEmpty(予算コード) ? &quot;&quot; : (予算コード.Length &lt; 9 ? &quot;&quot; : 予算コード.Substring(8, (予算コード.Length &gt;= 10 ? 2 : (予算コード.Length - 8))))) + &quot;)&quot; " FieldType="None" />
  </CalculatedFields>
  <Script><![CDATA[using System.Linq;

bool　ds存体;
private Dictionary<string, decimal> totalGroup款_執行累計1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup項_執行累計1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup目_執行累計1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup節_執行累計1 = new Dictionary<string, decimal>();

private Dictionary<string, decimal> totalGroup款_当月執行額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup項_当月執行額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup目_当月執行額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup節_当月執行額1 = new Dictionary<string, decimal>();

private Dictionary<string, decimal> totalGroup款_当初予算額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup項_当初予算額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup目_当初予算額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup節_当初予算額1 = new Dictionary<string, decimal>();

private Dictionary<string, decimal> totalGroup款_補正予算額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup項_補正予算額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup目_補正予算額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup節_補正予算額1 = new Dictionary<string, decimal>();

private Dictionary<string, decimal> totalGroup款_予備費支出額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup項_予備費支出額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup目_予備費支出額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup節_予備費支出額1 = new Dictionary<string, decimal>();

private Dictionary<string, decimal> totalGroup款_流用増減額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup項_流用増減額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup目_流用増減額1 = new Dictionary<string, decimal>();
private Dictionary<string, decimal> totalGroup節_流用増減額1 = new Dictionary<string, decimal>();

/// <summary>
/// レポート開始時（ReportStart）に初期設定を行う。
/// - データソースの妥当性チェック
/// - 並び順（ソート）の適用
/// - CrossSectionBox の罫線設定（必要時のみ）
/// </summary>
public void ActiveReport_ReportStart()
{
	
	if (CrossSectionBox1 != null)
		CrossSectionBox1.CloseBorder = true;
	
	SetBgColorTransparentAllSections();
	
	ds存体 = CheckDataSource();
	if (!ds存体) return;
	
	ApplySort_SumGroup();

}

/// <summary>
/// Section3 の Format イベント。
/// Crystal Reports の計算式（予算残額／執行率）を再現して、表示フィールドに反映する。
/// </summary>
public void Section3_Format()
{
	if (!ds存体) return;
	
	System.Data.DataTable dt = rpt.DataSource as System.Data.DataTable;
	if (!dt.Columns.Contains("累計予定額")) return;  
	/* CR Formula: 予算残額
	{@予算現額} - {帳票データ.累計予定額}
	*/
	this.Field17.Text = (TryDecimal(this.Field19.Value) - TryDecimal(rpt.Fields["累計予定額"].Value)).ToString("#,##0");
	
	/* CR Formula: 執行率
	if {帳票データ.累計予定額} = 0 or {@予算現額} = 0 then 0
	else {帳票データ.累計予定額}/{@予算現額}*100
	*/
	if (TryDecimal(rpt.Fields["累計予定額"].Value) == 0 || TryDecimal(this.Field19.Value) == 0)
	{
		this.Field18.Value = 0;
	}
	else
	{
		this.Field18.Value = (TryDecimal(rpt.Fields["累計予定額"].Value) / TryDecimal(this.Field19.Value)) * 100;
	}
	
	/*
	if {@予算現額} = 0 then
	    // 非表示 true
	    true
	else
	    // 非表示 false
	    false
	*/
	this.Section3.Visible = (TryDecimal(this.Field19.Value) != 0);
}


public void Section5_Format()
{
	if (!ds存体) return;
	
	#region 非表示
	this.Field9.Visible = rpt.Fields["見出区分"].Value.ToString().Contains("TIMESTAMPON");
	#endregion
	
	#region Formula [@タイムスタンプ]
	// カルチャの「言語-国/地域」を「日本語-日本」に設定します。
	System.Globalization.CultureInfo ci = new System.Globalization.CultureInfo("ja-JP");
	// 和暦を表すクラスです。
	System.Globalization.JapaneseCalendar jp = new System.Globalization.JapaneseCalendar();
	
	// 現在のカルチャで使用する暦を、和暦に設定します。
	ci.DateTimeFormat.Calendar = jp;
	// 「書式」「カルチャの書式情報」を使用し、文字列に変換します。
	this.Field9.Text = DateTime.Now.ToString("gg yy年MM月dd日 HH:mm:ss", ci);
	#endregion
	
}


/// <summary>
/// object を decimal に変換するユーティリティ。
/// 変換に失敗した場合は 0 を返し、帳票計算中の例外を防ぐ。
/// </summary>
/// <param name="value">数値として扱いたい値。</param>
/// <returns>変換後の decimal。失敗時は 0。</returns>
decimal TryDecimal(object value)
{
	
	decimal outValue = 0M;
	if (decimal.TryParse(value.ToString(), out outValue))
	{
		return outValue;
	}
	else
	{
		return 0M;
	}
}

/// <summary>
/// レポートのデータソースに対して、Crystal Reports 側の並び順に近い形でソートを適用する。
/// 予算コードから科目コードの階層キー（款/項/目/節）を生成し、体系区分→階層→予算コードの順で並べ替える。
/// </summary>
private void ApplySort_SumGroup()
{
	
	System.Data.DataTable dt = rpt.DataSource as System.Data.DataTable;
	if (!dt.Columns.Contains("予算コード")) return; 
	
	AddCol(dt, "科目コード_款", typeof(string));
	AddCol(dt, "科目コード_項", typeof(string));
	AddCol(dt, "科目コード_目", typeof(string));
	AddCol(dt, "科目コード_節", typeof(string));
	
	
	//不使用
	AddCol(dt, "執行累計1_temp", typeof(string));
	AddCol(dt, "当月執行額1_temp", typeof(string));
	AddCol(dt, "当初予算額1_temp", typeof(string));
	AddCol(dt, "補正予算額1_temp", typeof(string));
	
	AddCol(dt, "予備費支出額1_temp", typeof(string));
	AddCol(dt, "流用増減額1_temp", typeof(string));

	for (int r = 0; r < dt.Rows.Count; r++)
	{
		string 予算コード_temp = Convert.ToString(dt.Rows[r]["予算コード"]);
		//{帳票データ.予算コード}[ 1 TO 2 ]
		dt.Rows[r]["科目コード_款"] = GetCrystalSubstring(予算コード_temp, 1, 2);
		//{帳票データ.予算コード}[ 1 TO 4 ]
		dt.Rows[r]["科目コード_項"] = GetCrystalSubstring(予算コード_temp, 1, 4);
		//{帳票データ.予算コード}[ 1 TO 6 ]
		dt.Rows[r]["科目コード_目"] = GetCrystalSubstring(予算コード_temp, 1, 6);
		//{帳票データ.予算コード}[ 1 TO 8 ]
		dt.Rows[r]["科目コード_節"] = GetCrystalSubstring(予算コード_temp, 1, 8);
		
		
		//不使用 
		/*if {帳票データ.予算サイン} ='1'  then {帳票データ.累計予定額}
		else  0
		*/
		dt.Rows[r]["執行累計1_temp"] = Convert.ToString(dt.Rows[r]["予算サイン"]) == "1" ? Convert.ToString(dt.Rows[r]["累計予定額"]) : "0";
		/*if {帳票データ.予算サイン} ='1'  then {帳票データ.当月予定額}
 		else  0
		*/
		dt.Rows[r]["当月執行額1_temp"] = Convert.ToString(dt.Rows[r]["予算サイン"]) == "1" ? Convert.ToString(dt.Rows[r]["当月予定額"]) : "0";
		/*if {帳票データ.予算サイン} ='1'  then {帳票データ.当初予算額}
 		else  0
		*/
		dt.Rows[r]["当初予算額1_temp"] = Convert.ToString(dt.Rows[r]["予算サイン"]) == "1" ? Convert.ToString(dt.Rows[r]["当初予算額"]) : "0";
		/*if {帳票データ.予算サイン} = '1' then{帳票データ.補正予算額}
 		else 0
		*/
		dt.Rows[r]["補正予算額1_temp"] = Convert.ToString(dt.Rows[r]["予算サイン"]) == "1" ? Convert.ToString(dt.Rows[r]["補正予算額"]) : "0";
		/*if {帳票データ.予算サイン} = '1' then{帳票データ.予備費支出額}
		 else 0
		*/
		dt.Rows[r]["予備費支出額1_temp"] = Convert.ToString(dt.Rows[r]["予算サイン"]) == "1" ? Convert.ToString(dt.Rows[r]["予備費支出額"]) : "0";
		/*if {帳票データ.予算サイン} = '1' then{帳票データ.流用増減額}
 		else 0
		*/
		dt.Rows[r]["流用増減額1_temp"] = Convert.ToString(dt.Rows[r]["予算サイン"]) == "1" ? Convert.ToString(dt.Rows[r]["流用増減額"]) : "0";
		//
	}
	
	//末尾に残っている「予算現額_Cal = 0」の行（実質的に空データ）を削除する。
	//これにより、明細が無いのに次ページが発生して PageHeader だけが余分に印字される（最後の空白ページ）ケースを防止する。
	for (int i = dt.Rows.Count - 1; i >= 0; i--)
	{
		decimal val = TryDecimal(dt.Rows[i]["当初予算額"]) + TryDecimal(dt.Rows[i]["補正予算額"]) 
			+ TryDecimal(dt.Rows[i]["流用増減額"]) + TryDecimal(dt.Rows[i]["予備費支出額"]) + TryDecimal(dt.Rows[i]["繰越予算額"]);

		if (val == 0m)
		{
			dt.Rows.RemoveAt(i);   
		}
		else
		{
			break;                 
		}
	}

