public bool ActiveReport_FetchData(bool eof)
{
	try
	{
		if (eof) return eof;
		//{帳票データ.予算コード}[ 1 TO 10 ]
		rpt.CalculatedFields["科目コード_細"].Value = GetCrystalSubstring(Convert.ToString(rpt.Fields["予算コード"].Value), 1, 10);

		return eof;
	}
	catch{
		return true;
	}
}

